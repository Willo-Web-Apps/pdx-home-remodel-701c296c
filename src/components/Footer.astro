---
const year = new Date().getFullYear();
---
<footer class="bg-surface-900 text-surface-300">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-14 md:py-16">

    <div class="grid grid-cols-1 md:grid-cols-3 gap-10 pb-10 border-b border-surface-800/60">

      <!-- Brand column -->
      <div class="col-span-1">
        <a href="/" class="flex items-center gap-2.5 mb-4">
          <div class="w-8 h-8 rounded-lg bg-brand-500 flex items-center justify-center flex-shrink-0">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-4 h-4 text-surface-50">
              <path d="M10.707 2.293a1 1 0 0 0-1.414 0l-7 7a1 1 0 0 0 1.414 1.414L4 10.414V17a1 1 0 0 0 1 1h2a1 1 0 0 0 1-1v-2a1 1 0 0 1 1-1h2a1 1 0 0 1 1 1v2a1 1 0 0 0 1 1h2a1 1 0 0 0 1-1v-6.586l.293.293a1 1 0 0 0 1.414-1.414l-7-7Z" />
            </svg>
          </div>
          <span class="font-display font-bold text-base text-surface-50 tracking-tight">PDX Home Remodel</span>
        </a>
        <p class="font-body text-sm leading-relaxed text-surface-400 max-w-xs">
          Portland's most trusted deck builders. Custom composite decks, covered outdoor living, and honest craftsmanship since 2012.
        </p>
        <p class="mt-4 font-body text-sm text-cedar-400 font-medium">Portland's Most Trusted Deck Builders</p>
      </div>

      <!-- Services -->
      <div>
        <p class="font-body font-semibold text-surface-50 text-sm mb-4 uppercase tracking-widest">Services</p>
        <ul class="space-y-2.5">
          <li><a href="#work" class="font-body text-sm text-surface-400 hover:text-surface-200 transition-colors">Custom Composite Decks</a></li>
          <li><a href="#work" class="font-body text-sm text-surface-400 hover:text-surface-200 transition-colors">Covered Outdoor Spaces</a></li>
          <li><a href="#work" class="font-body text-sm text-surface-400 hover:text-surface-200 transition-colors">Deck Repair & Replacement</a></li>
          <li><a href="#contact" class="font-body text-sm text-surface-400 hover:text-surface-200 transition-colors">Free Estimate</a></li>
        </ul>
      </div>

      <!-- Contact -->
      <div>
        <p class="font-body font-semibold text-surface-50 text-sm mb-4 uppercase tracking-widest">Contact</p>
        <ul class="space-y-2.5">
          <li>
            <a href="tel:+15035550100" class="font-body text-sm text-surface-400 hover:text-surface-200 transition-colors flex items-center gap-2">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16" fill="currentColor" class="w-3.5 h-3.5 text-cedar-500 flex-shrink-0">
                <path fill-rule="evenodd" d="M1.885.511a1.745 1.745 0 0 1 2.61.163L6.29 2.98c.329.423.445.974.315 1.494l-.547 2.19a.678.678 0 0 0 .178.643l2.457 2.457a.678.678 0 0 0 .644.178l2.189-.547a1.745 1.745 0 0 1 1.494.315l2.306 1.794c.829.645.905 1.87.163 2.611l-1.034 1.034c-.74.74-1.846 1.065-2.877.702a18.634 18.634 0 0 1-7.01-4.42 18.634 18.634 0 0 1-4.42-7.009c-.362-1.03-.037-2.137.703-2.877L1.885.511Z" clip-rule="evenodd" />
              </svg>
              (503) 555-0100
            </a>
          </li>
          <li>
            <a href="mailto:hello@pdxhomeremodel.com" class="font-body text-sm text-surface-400 hover:text-surface-200 transition-colors flex items-center gap-2">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16" fill="currentColor" class="w-3.5 h-3.5 text-cedar-500 flex-shrink-0">
                <path d="M1.75 2h12.5c.966 0 1.75.784 1.75 1.75v8.5A1.75 1.75 0 0 1 14.25 14H1.75A1.75 1.75 0 0 1 0 12.25v-8.5C0 2.784.784 2 1.75 2ZM1.5 5.871v6.379c0 .138.112.25.25.25h12.5a.25.25 0 0 0 .25-.25V5.871l-5.441 3.338a1.75 1.75 0 0 1-1.818 0L1.5 5.871Zm13-2.371H1.5l6.25 3.838L14.5 3.5Z" />
              </svg>
              hello@pdxhomeremodel.com
            </a>
          </li>
          <li class="font-body text-sm text-surface-400 flex items-center gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16" fill="currentColor" class="w-3.5 h-3.5 text-cedar-500 flex-shrink-0">
              <path fill-rule="evenodd" d="m7.539 14.841.003.003.002.002a.755.755 0 0 0 .912 0l.002-.002.003-.003.012-.009a5.57 5.57 0 0 0 .19-.153 15.588 15.588 0 0 0 2.046-2.082c1.101-1.362 2.291-3.342 2.291-5.597A5 5 0 0 0 3 7c0 2.255 1.19 4.235 2.292 5.597a15.591 15.591 0 0 0 2.046 2.082 8.916 8.916 0 0 0 .189.153l.012.01ZM8 8.5a1.5 1.5 0 1 0 0-3 1.5 1.5 0 0 0 0 3Z" clip-rule="evenodd" />
            </svg>
            Portland Metro Area, OR
          </li>
          <li class="font-body text-sm text-surface-400">Licensed & insured · CCB #XXXXXX</li>
        </ul>
      </div>

    </div>

    <div class="pt-8 flex flex-col sm:flex-row items-center justify-between gap-3">
      <p class="font-body text-sm text-surface-500">&copy; {year} PDX Home Remodel. All rights reserved.</p>
      <p class="font-body text-xs text-surface-600">Serving Portland, Lake Oswego, Beaverton, Gresham, and the greater PDX metro</p>
    </div>

  </div>
</footer>
